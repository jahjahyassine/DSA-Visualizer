# Code Visualizer — Backend Environment Variables
# Copy this file to .env and adjust values as needed

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS — add your frontend URL here
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Execution sandbox limits
MAX_EXECUTION_TIME=10
MAX_MEMORY_MB=128
MAX_OUTPUT_LINES=1000
MAX_STEPS=5000

# Docker sandbox (set to true if Docker is available)
USE_DOCKER_SANDBOX=false
DOCKER_IMAGE=code-visualizer-sandbox:latest
